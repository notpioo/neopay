# =====================================================
# NeoPay — Environment Variables
# Salin file ini ke .env dan isi nilainya
# =====================================================

# ------ Supabase (wajib) ------
# URL project Supabase (dari Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key — jangan expose ke frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Connection string ke Postgres (dari Settings > Database > Connection string)
# Gunakan mode "Session" (port 5432) atau "Transaction" (port 6543)
# Jika password mengandung karakter '@', encode sebagai %40
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:your-password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ------ OneSignal (opsional — push notification Android) ------
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_API_KEY=your-onesignal-rest-api-key

# ------ Runtime ------
# Railway menyediakan PORT secara otomatis, tidak perlu diisi manual
PORT=3000

# Mode aplikasi: production | development
NODE_ENV=production

# Base path untuk frontend (Railway: /, Replit: /dashboard)
BASE_PATH=/
